# Get your Google Maps API key at https://console.cloud.google.com/apis/credentials
# Enable: Places API, Geocoding API, Distance Matrix API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: YouTube Data API v3 key for place videos
# Get at https://console.cloud.google.com/apis/credentials
# Free tier: 10,000 quota units/day (~100 searches)
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
